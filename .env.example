# drafts v0.2 — environment configuration
# Copy to /etc/labs/drafts.env (production) or ./drafts.env (dev)

# REQUIRED: Public base URL of this server (no trailing slash)
PUBLIC_BASE_URL=https://drafts.example.com

# OPTIONAL: Server number for the federation registry
# Default: 0 (unregistered, local). Claim a public number by opening a PR
# against https://github.com/g0rd33v/drafts-protocol/blob/main/drafts-registry.json
SERVER_NUMBER=0

# OPTIONAL: Internal HTTP port (nginx proxies to this)
PORT=3100

# OPTIONAL: Where project files and .state.json live
DRAFTS_DIR=/var/lib/drafts

# OPTIONAL: Pre-set the SAP token. If omitted, a fresh SAP is auto-minted on
# first run and saved to /etc/labs/drafts.sap (mode 0600). Save it immediately —
# it is the only time the token is shown in plaintext.
# BEARER_TOKEN=

# OPTIONAL: Legacy GitHub sync env vars. Prefer the runtime API:
#   PUT /drafts/config/github           (SAP — server default)
#   PUT /drafts/projects/:name/config/github  (PAP — per-project override)
# These env vars are used only as a last-resort fallback if no runtime config exists.
# GITHUB_USER=
# GITHUB_TOKEN=
